# Backend API URL
PROJECT_NAME="缺陷管理系统"

# MySQL Configuration
MYSQL_SERVER=localhost
MYSQL_PORT=3306
MYSQL_DB=qa_assistant
MYSQL_USER=root
MYSQL_PASSWORD=your_password_here

# MongoDB Configuration
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=test_platform

# Apifox Configuration
APIFOX_ACCESS_TOKEN=your_apifox_token_here
