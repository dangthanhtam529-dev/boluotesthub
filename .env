# ============================================
# 域名配置 (Domain Configuration)
# ============================================
# 部署时通过环境变量设置为生产域名
# Traefik 使用此域名来路由流量和获取 TLS/SSL 证书
DOMAIN=localhost

# 用于测试本地 Traefik 配置（使用子域名）
# DOMAIN=localhost.tiangolo.com

# ============================================
# 前端地址 (Frontend URL)
# ============================================
# 后端生成邮件中的链接时使用此地址
FRONTEND_HOST=http://localhost:5173

# 在预发布和生产环境中，设置为实际的前端域名
# FRONTEND_HOST=https://dashboard.example.com

# ============================================
# 运行环境 (Environment)
# ============================================
# 可选值: local(本地开发), staging(预发布), production(生产)
ENVIRONMENT=local

# ============================================
# 项目信息 (Project Info)
# ============================================
# 项目名称（显示在 API 文档等地方）
PROJECT_NAME="Full Stack FastAPI Project"

# 堆栈名称（用于 Docker Compose 标签和项目名称）
# 注意：不能包含空格和特殊字符
STACK_NAME=full-stack-fastapi-project

# ============================================
# 后端配置 (Backend Configuration)
# ============================================
# CORS 跨域配置 - 允许访问后端的域名列表
# 开发环境包含多个本地地址
BACKEND_CORS_ORIGINS="http://localhost,http://localhost:5173,https://localhost,https://localhost:5173,http://localhost.tiangolo.com"

# 安全密钥 - 用于加密 JWT Token 等
# ⚠️ 重要：生产环境必须修改！
# 生成命令：python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=urXqaHhYAs4sl8-xapGAT4rGUES7i-6P_26vkhjmd9Q

# 第一个超级管理员账号
# 系统启动时会自动创建此用户
FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=changethis

# ============================================
# 邮件配置 (Email Configuration)
# ============================================
# SMTP 服务器地址（留空表示不启用邮件功能）
SMTP_HOST=

# SMTP 用户名和密码
SMTP_USER=
SMTP_PASSWORD=

# 发件人邮箱地址
EMAILS_FROM_EMAIL=info@example.com

# SMTP 加密设置
SMTP_TLS=True      # 启用 TLS 加密
SMTP_SSL=False     # 启用 SSL 加密（与 TLS 二选一）
SMTP_PORT=587      # SMTP 端口（TLS 常用 587，SSL 常用 465）

# ============================================
# MySQL 数据库配置 (Database Configuration)
# ============================================
# 数据库服务器地址
# localhost - 使用本地安装的 MySQL
# db - 使用 Docker Compose 中的 MySQL 服务
MYSQL_SERVER=localhost

# 数据库端口（MySQL 默认 3306）
MYSQL_PORT=3306

# 数据库名称
MYSQL_DB=qa_assistant

# 数据库用户名（建议生产环境使用非 root 账号）
MYSQL_USER=root

# 数据库密码
# ⚠️ 重要：部署前必须修改！
MYSQL_PASSWORD=123456

# MySQL root 密码（Docker 方式部署时需要）
MYSQL_ROOT_PASSWORD=123456

# ============================================
# 监控配置 (Monitoring)
# ============================================
# Sentry DSN - 用于错误追踪和性能监控
# 留空表示不启用 Sentry
SENTRY_DSN=

# ============================================
# Docker 镜像配置 (Docker Images)
# ============================================
# 后端和前端服务的 Docker 镜像名称
# 部署时修改为实际的镜像仓库地址
DOCKER_IMAGE_BACKEND=backend
DOCKER_IMAGE_FRONTEND=frontend

# ============================================
# Apifox 配置
# ============================================
# Apifox Access Token - 用于访问 Apifox API
# 在 Apifox 网站生成：账号设置 -> API 访问令牌
APIFOX_ACCESS_TOKEN=afxp_437d83PAfjab8eR7KPPfr4FDlCTalSnsabaJ
# Apifox 默认项目 ID（可选，创建项目时可指定）
APIFOX_PROJECT_ID=
